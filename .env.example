# Where the app reads the DeepSeek forecast bridge contract.
# Dev: the bundled public/forecast_provinces.json (synced from DeepSeek).
# Prod: the published GitHub Pages URL (the heatwave-contract repo).
EXPO_PUBLIC_FORECAST_URL=https://mcteekung.github.io/heatwave-contract/forecast_provinces.json

# Google Places API key (New Places API) — for the in-app Cool Shelter Finder
# Create at https://console.cloud.google.com → Enable "Places API (New)" → Restrict key to this app
# Without this key the finder falls back to OpenStreetMap Overpass (less accurate for Thailand)
EXPO_PUBLIC_GOOGLE_PLACES_KEY=
