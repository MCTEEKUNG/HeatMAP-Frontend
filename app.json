{
  "expo": {
    "name": "Heatwave Forecast",
    "slug": "heatwave-forecast",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "heatwave",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#a933a6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.heatwave.forecast"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#a933a6",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "fonts": [
        "./node_modules/@expo-google-fonts/inter/Inter_300.ttf",
        "./node_modules/@expo-google-fonts/inter/Inter_400.ttf",
        "./node_modules/@expo-google-fonts/inter/Inter_500.ttf",
        "./node_modules/@expo-google-fonts/inter/Inter_600.ttf",
        "./node_modules/@expo-google-fonts/inter/Inter_700.ttf"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#a933a6"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./node_modules/@expo-google-fonts/inter/Inter_300.ttf",
            "./node_modules/@expo-google-fonts/inter/Inter_400.ttf",
            "./node_modules/@expo-google-fonts/inter/Inter_500.ttf",
            "./node_modules/@expo-google-fonts/inter/Inter_600.ttf",
            "./node_modules/@expo-google-fonts/inter/Inter_700.ttf"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
